{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "chrome"
    ],
    "strict": false,
    "skipLibCheck": true,
    "sourceMap": false,
    "noEmit": true,
    "noEmitOnError": false
  },
  "include": [
    "src/**/*.ts",
    "vite.config.ts"
  ]
}
