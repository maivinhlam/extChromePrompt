{
  "manifest_version": 3,
  "name": "Flow Prompt Runner",
  "version": "1.0.0",
  "description": "Run prompt lines in Google Labs Flow with timed sending, retries, and auto download naming.",
  "permissions": ["activeTab", "storage", "downloads"],
  "host_permissions": ["https://labs.google/*", "https://*.labs.google/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Flow Prompt Runner"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/*", "https://*.labs.google/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
